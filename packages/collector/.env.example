# Collector를 컨테이너 없이 단독 실행할 때만 .env로 복사합니다.
DATABASE_URL=postgresql://coc:replace-with-database-password@127.0.0.1:5432/multi_coc
DATA_DIR=../../data
PORT=8787
CORS_ORIGIN=http://localhost:3000

# 공식 Player API로 이름·타운홀·레벨을 보강할 때 사용하는 개발자 서버 키입니다.
