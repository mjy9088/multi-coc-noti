# Notifier를 컨테이너 없이 단독 실행할 때만 .env로 복사합니다.
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=multi_coc
PGUSER=coc
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
BARK_DEVICE_KEY=replace-with-bark-device-key
BARK_BASE_URL=https://api.day.app
BARK_GROUP="Multi CoC Noti"
NOTIFICATION_LOCALE=ko
NOTIFIER_INTERVAL_SECONDS=10
