{
  "name": "multi-coc-noti",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @multi-coc/dashboard dev",
    "build": "pnpm --filter @multi-coc/dashboard build",
    "start": "pnpm --filter @multi-coc/dashboard start",
    "collector": "pnpm --filter @multi-coc/collector start",
    "notifier": "pnpm --filter @multi-coc/notifier start",
    "format": "biome check --write",
    "format:check": "biome ci",
    "typecheck": "tsc --noEmit && pnpm --filter @multi-coc/dashboard typecheck",
    "test": "pnpm typecheck && pnpm --filter @multi-coc/reverse-proxy test && pnpm --filter @multi-coc/upgrade-availability test && pnpm --filter @multi-coc/village-export test && pnpm --filter @multi-coc/notification-policy test && pnpm --filter @multi-coc/collector test && pnpm --filter @multi-coc/notifier test && pnpm build",
    "lint": "biome lint && pnpm --filter @multi-coc/dashboard lint"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "lefthook": "2.1.10",
    "typescript": "5.9.3"
  }
}
