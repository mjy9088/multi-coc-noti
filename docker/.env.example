# Docker Compose 전용 설정입니다. 계정은 관리 화면에서 DB에 추가합니다.
# 대시보드 관리자 로그인에 입력하는 값입니다.
ADMIN_TOKEN=replace-with-a-long-random-admin-token
# PostgreSQL 전용이며 관리자 로그인에는 사용할 수 없습니다.
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_PORT=5432

# 관리 화면의 계정별 토큰 대신 공용 공식 API 토큰을 쓸 때만 설정합니다.
# CLASH_OF_CLANS_API_TOKEN=official-developer-api-token

BARK_DEVICE_KEY=replace-with-bark-device-key
BARK_BASE_URL=https://api.day.app
BARK_GROUP="Multi CoC Noti"
NOTIFICATION_LOCALE=ko
POLL_INTERVAL_SECONDS=300
NOTIFIER_INTERVAL_SECONDS=10
INGEST_RATE_LIMIT_PER_MINUTE=120
SNAPSHOT_RETENTION_DAYS=90
CORS_ORIGIN=http://localhost:3000

# dashboard 이미지 빌드 시 포함되는 공개 설정입니다. 비밀값을 넣지 마세요.
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false
