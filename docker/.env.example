# Docker Compose 전용 설정입니다.

POSTGRES_PASSWORD=replace-with-a-long-random-database-password
POSTGRES_PORT=5432

# `openssl rand -base64 32` 등으로 생성합니다.
AUTH_SECRET=replace-with-a-long-random-auth-secret
# 사용할 소셜 로그인 제공자를 설정합니다. 테스트 로그인으로 대체할 수도 있습니다.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# 로컬·테스트 환경에서만 세 값을 모두 설정합니다. 활성화하지 않으면 로그인 UI에도 표시되지 않습니다.
# AUTH_TEST_CREDENTIALS_ENABLED=true
# AUTH_TEST_USERNAME=
# AUTH_TEST_PASSWORD=

# 공식 Player API로 이름·타운홀·레벨을 보강할 때 사용하는 개발자 서버 키입니다.
# CLASH_OF_CLANS_API_TOKEN=official-developer-api-token

PROFILE_REFRESH_INTERVAL_SECONDS=300
NOTIFIER_INTERVAL_SECONDS=10
CORS_ORIGIN=http://localhost:3000

# dashboard 이미지 빌드 시 포함되는 공개 설정입니다. 비밀값을 넣지 마세요.
# Gateway가 Auth.js와 Collector API를 같은 origin으로 제공하므로 통합 개발·프로덕션에서는 same-origin을 사용합니다.
NEXT_PUBLIC_API_BASE=same-origin
NEXT_PUBLIC_SITE_URL=http://localhost:3000
