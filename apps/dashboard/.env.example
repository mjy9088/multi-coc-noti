# Next.js 대시보드를 컨테이너 없이 단독 실행할 때만 .env.local로 복사합니다.
# NEXT_PUBLIC_* 값은 브라우저에 공개되므로 비밀값을 넣지 마세요.
NEXT_PUBLIC_API_BASE=http://localhost:8787
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DATABASE_URL=postgresql://coc:replace-with-database-password@127.0.0.1:5432/multi_coc
AUTH_SECRET=replace-with-a-long-random-auth-secret
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# 로컬 테스트 로그인 폼이 필요할 때만 세 값을 모두 설정합니다.
# AUTH_TEST_CREDENTIALS_ENABLED=true
# AUTH_TEST_USERNAME=
# AUTH_TEST_PASSWORD=
